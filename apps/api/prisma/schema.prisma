// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum AvailStatus {
  OPEN
  BUSY
  UNAVAILABLE
}

enum ProjectStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum ProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum NotifType {
  PROPOSAL_ACCEPTED
  PROPOSAL_RECEIVED
  NEW_MESSAGE
  ROOM_LIVE
  ARTICLE_BOOKMARKED
  XP_MILESTONE
  PROJECT_MEMBER_JOINED
}

enum ArticleSource {
  RSS
  COMMUNITY
  CURATED
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id             String      @id @default(cuid())
  username       String      @unique
  email          String      @unique
  passwordHash   String?
  githubId       String?     @unique
  googleId       String?     @unique
  avatar         String?
  bio            String?     @db.VarChar(500)
  githubUrl      String?
  portfolioLinks String[]    @default([])
  availability   AvailStatus @default(OPEN)
  xp             Int         @default(0)

  // Relations
  skills              UserSkill[]
  ownedProjects       Project[]          @relation("OwnedProjects")
  projectMemberships  ProjectMember[]
  proposals           Proposal[]
  articles            Article[]
  comments            Comment[]
  bookmarks           Bookmark[]
  notifications       Notification[]
  sentMessages        DirectMessage[]    @relation("SentMessages")
  conversations       ConversationParticipant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([username])
  @@index([email])
}

model Skill {
  id       String      @id @default(cuid())
  name     String      @unique
  category String?
  users    UserSkill[]
}

model UserSkill {
  userId  String
  skillId String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill   Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([userId, skillId])
}

// ─── Project ─────────────────────────────────────────────────────────────────

model Project {
  id          String        @id @default(cuid())
  title       String        @db.VarChar(120)
  description String        @db.Text
  techTags    String[]
  status      ProjectStatus @default(OPEN)
  ownerId     String
  owner       User          @relation("OwnedProjects", fields: [ownerId], references: [id])
  members     ProjectMember[]
  roles       RoleOpening[]
  proposals   Proposal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([ownerId])
}

model ProjectMember {
  projectId String
  userId    String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now())

  @@id([projectId, userId])
}

model RoleOpening {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String    @db.VarChar(80)
  description String?   @db.VarChar(1000)
  techTags    String[]
  isPaid      Boolean   @default(false)
  filledBy    String?
  proposals   Proposal[]
  createdAt   DateTime  @default(now())
}

model Proposal {
  id        String         @id @default(cuid())
  projectId String
  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roleId    String?
  role      RoleOpening?   @relation(fields: [roleId], references: [id])
  authorId  String
  author    User           @relation(fields: [authorId], references: [id])
  content   String         @db.VarChar(2000)
  status    ProposalStatus @default(PENDING)
  createdAt DateTime       @default(now())

  @@index([projectId, status])
}

// ─── Room ────────────────────────────────────────────────────────────────────

model Room {
  id              String   @id @default(cuid())
  name            String   @db.VarChar(80)
  description     String?  @db.VarChar(500)
  hostId          String
  isLive          Boolean  @default(false)
  maxMembers      Int      @default(50)
  tags            String[]
  recordingEnabled Boolean @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isLive])
  @@index([hostId])
}

// ─── News ────────────────────────────────────────────────────────────────────

model Article {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String        @db.VarChar(200)
  excerpt     String?       @db.VarChar(500)
  content     String?       @db.Text
  source      ArticleSource @default(COMMUNITY)
  externalUrl String?
  authorId    String?
  author      User?         @relation(fields: [authorId], references: [id])
  tags        String[]
  views       Int           @default(0)
  published   Boolean       @default(false)
  publishedAt DateTime?
  comments    Comment[]
  bookmarks   Bookmark[]
  createdAt   DateTime      @default(now())

  @@index([published, publishedAt])
  @@index([slug])
}

model Comment {
  id        String    @id @default(cuid())
  articleId String
  article   Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  authorId  String
  author    User      @relation(fields: [authorId], references: [id])
  content   String    @db.VarChar(2000)
  parentId  String?
  parent    Comment?  @relation("Replies", fields: [parentId], references: [id])
  replies   Comment[] @relation("Replies")
  createdAt DateTime  @default(now())

  @@index([articleId])
}

model Bookmark {
  userId    String
  articleId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, articleId])
}

// ─── Messaging ───────────────────────────────────────────────────────────────

model Conversation {
  id           String                   @id @default(cuid())
  participants ConversationParticipant[]
  messages     DirectMessage[]
  updatedAt    DateTime                 @updatedAt
  createdAt    DateTime                 @default(now())
}

model ConversationParticipant {
  conversationId String
  userId         String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
}

model DirectMessage {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
  content        String       @db.VarChar(4000)
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// ─── Notifications ───────────────────────────────────────────────────────────

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotifType
  title     String    @db.VarChar(200)
  body      String    @db.VarChar(500)
  href      String?
  read      Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@index([userId, read])
}
